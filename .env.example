# Supabase project the SPA talks to directly (browser + anon key, RLS-guarded).
# For local dev, run `supabase start` and use the printed API URL + anon key.
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=your-anon-key

# Only for the RLS integration test (npm run test against a local Supabase):
# SUPABASE_TEST_URL=http://localhost:54321
# SUPABASE_TEST_ANON_KEY=your-anon-key
